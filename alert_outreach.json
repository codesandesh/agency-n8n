    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + $env.GOOGLE_AI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"contents\": [{\"parts\": [{\"text\": `You are writing as Ujjwal Roy, CEO of ScaleBuild AI (Junkiri Labs LLC).\n\nLEAD:\nTitle: ${$json[\"Title\"] || $json.title || \"\"}\nSummary: ${$json[\"AI Summary\"] || $json.ai_summary || \"\"}\nIndustry: ${$json[\"Industry\"] || $json.industry || \"\"}\nTech Stack: ${$json[\"Tech Stack\"] || ($json.tech_stack||[]).join(', ') || \"Not specified\"}\nBudget: ${$json[\"Budget Mentioned\"] || $json.estimated_budget_text || \"Not mentioned\"}\nSource: r/${$json[\"Subreddit\"] || $json.subreddit || \"HackerNews\"}\n\nRULES:\n- Write a Reddit DM as Ujjwal Roy, CEO of ScaleBuild AI\n- Tone: casual, human, conversational \u2014 like one founder messaging another\n- Max 100 words, no fluff\n- Start by referencing their specific pain point\n- Briefly mention ScaleBuild AI helps with AI/automation (Intel/IBM/Micron background)\n- End with a soft CTA\n- NO em dashes, NO exclamation marks\n- End with:\n\nRegards,\nUjjwal\nScaleBuild AI\n\nReturn ONLY the message text. No markdown.`}]}],\n  \"generationConfig\": {\"maxOutputTokens\": 6000, \"temperature\": 0.6}\n}) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "gemini-outreach",
      "name": "Gemini - Generate Outreach",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3760,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const geminiResp = $input.item.json;\nconst d = $('Check - Score >= 0.50 (Instant Alert)').item.json;\nconst draft = geminiResp.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || 'Outreach generation failed';\nconst author = d['Author'] || 'unknown';\nconst sourceUrl = d['Source URL'] || '';\nlet domain = '';\ntry { domain = new URL(sourceUrl).hostname.replace('www.', ''); } catch(e) {}\nconst subreddit = d['Subreddit'] || '';\nconst sourceLine = subreddit ? ('r/' + subreddit + (domain ? '  ·  ' + domain : '')) : domain;\nconst lines = [\n  'Lead Alert',\n  'Score ' + d['Overall Score'],\n  d['Industry'] || '',\n  d['Title'] || '',\n  '',\n  sourceLine,\n  '',\n  'Relevance        ' + (d['Relevance Score'] || ''),\n  'Budget fit       ' + (d['Budget Score'] || ''),\n  'Win probability  ' + (d['Win Probability'] || ''),\n  '',\n  'Summary',\n  (d['AI Summary'] || '').substring(0, 400),\n  '',\n  'Budget',\n  d['Budget Mentioned'] || 'Unknown',\n  '',\n  'Author',\n  'u/' + author,\n  '',\n  'Contact',\n  (d['Hunter Name'] || d['Lead Founder'] || 'N/A') + ' @ ' + (d['Hunter Company'] || d['Lead Company'] || 'N/A'),\n  '',\n  'Email',\n  d['Hunter Email'] || d['Lead Contact'] || 'Not found',\n  '',\n  'Outreach Draft',\n  '',\n  draft,\n  '',\n  'View project',\n  sourceUrl\n];\nconst whatsapp_message = lines.join('\\n');\nreturn [{ json: { ...d, outreach_draft: draft, whatsapp_message } }];"
      },
