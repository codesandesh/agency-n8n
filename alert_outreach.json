    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst budgetScore = parseFloat(d['Budget Score']) || 0;\nconst location = (d['Location'] || '').toLowerCase();\nconst industry = (d['Industry'] || '').toLowerCase();\nconst subreddit = (d['Subreddit'] || '').toLowerCase();\nconst title = (d['Title'] || '').toLowerCase();\nconst summary = (d['AI Summary'] || '').toLowerCase();\n\n// Block India / Pakistan / Bangladesh based freelancers\nconst isOffshoreFreelancer = location.includes('india') || location.includes('pakistan') || location.includes('bangladesh') || location.includes('sri lanka');\n\n// Block low-budget SaaS (SaaS + budget score below 0.50)\nconst isLowBudgetSaaS = (industry.includes('saas') || title.includes('saas') || summary.includes('saas')) && budgetScore < 0.50;\n\n// Block cheap freelance subreddits with low budget\nconst isCheapFreelance = ['slavelabour', 'forhire', 'indianfreelancers'].includes(subreddit) && budgetScore < 0.50;\n\nif (isOffshoreFreelancer || isLowBudgetSaaS || isCheapFreelance) {\n  return [];\n}\nreturn [$input.item];"
      },
      "id": "filter-qualify-lead",
      "name": "Filter - Qualify Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3400,
        160
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
